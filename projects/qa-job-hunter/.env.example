# Copiar a .env y completar ( .env no se sube a git )
LI_EMAIL=tu@email.com
LI_PASS=tu_password

# Proveedor de análisis de match — 3 opciones:
#   anthropic → Claude API (mejor calidad, consume tokens)
#   ollama    → LLM local, sin costo de tokens (requiere Ollama corriendo)
#   regex     → reglas locales, sin LLM ni API (reaseguro / offline)
# LLM_PROVIDER=regex

# Opcional — análisis en nube (Claude)
# ANTHROPIC_API_KEY=sk-ant-...

# Opcional — Ollama
# OLLAMA_MODEL=qwen2.5:1.5b
