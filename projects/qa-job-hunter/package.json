{
  "name": "qa-job-hunter",
  "version": "1.0.0",
  "type": "module",
  "description": "Agentic job hunter for QA roles - LinkedIn scraper + Claude match analysis",
  "scripts": {
    "login": "npx tsx src/1-login.ts",
    "scrape": "npx tsx src/2-scrape-jobs.ts",
    "analyze": "npx tsx src/3-analyze-match.ts",
    "full-run": "npx tsx src/run-all.ts",
    "dashboard": "npx tsx src/serve-dashboard.ts",
    "db:seed": "npx tsx src/db/seed.ts",
    "test:api": "npx tsx --test tests/api/jobs.test.ts",
