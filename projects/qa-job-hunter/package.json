{
  "name": "qa-job-hunter",
  "version": "1.0.0",
  "type": "module",
  "description": "Agentic job hunter for QA roles - LinkedIn scraper + Claude match analysis",
  "scripts": {
    "login": "npx tsx src/1-login.ts",
    "scrape": "npx tsx src/2-scrape-jobs.ts",
    "analyze": "npx tsx src/3-analyze-match.ts",
    "full-run": "npx tsx src/run-all.ts",
    "dashboard": "npx tsx src/serve-dashboard.ts",
    "db:seed": "npx tsx src/db/seed.ts",
    "test:api": "npx tsx --test tests/api/jobs.test.ts",
    "playwright:ide": "npx tsx src/open-playwright-ide.ts",
    "easy-apply": "npx tsx src/easy-apply.ts",
    "easy-apply:dry-run": "npx tsx src/easy-apply-dry-run.ts",
    "apply:sync": "npx tsx agents/excel-bridge/sync-only.ts",
    "tracker:sync": "npx tsx agents/excel-bridge/sync-only.ts",
    "campaign": "npx tsx src/campaign/run-campaign.ts",
    "agent:gmail-fetch": "npx tsx agents/gmail-fetch/run.ts",
    "agent:pipeline": "npx tsx agents/pipeline-match/run.ts",
    "agent:excel": "npx tsx agents/excel-bridge/run.ts",
    "agent:gmail-reconcile": "npx tsx agents/gmail-reconcile/run.ts",
    "test:apply-notes": "npx tsx --test tests/apply/failed-fields-notes.test.ts",
    "test:unknown-strategy": "npx tsx --test tests/apply/unknown-field-strategy.test.ts",
    "test:timing": "npx tsx --test tests/apply/timing.test.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.0",
    "mongodb": "^6.16.0",
    "playwright": "^1.44.0"
  },
  "devDependencies": {
    "tsx": "^4.11.0",
    "typescript": "^5.4.5",
    "@types/node": "^20.12.0"
  }
}
